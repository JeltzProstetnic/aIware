graph LR
    SENS[Sensory Input] --> IWM[IWM<br/>LLM #1 weights]
    SELF[Self-state] --> ISM[ISM<br/>LLM #1 weights]
    IWM --> GATE[Permeability<br/>Gate]
    ISM --> GATE
    GATE --> EWM[EWM<br/>LLM #2 generation]
    GATE --> ESM[ESM<br/>LLM #2 generation]
    ESM -->|self-ref loop| ESM
    EWM --> COMM[Communication LLM]
    ESM --> COMM
    style IWM fill:#D6EAF8,stroke:#1A5276,stroke-width:2px
    style ISM fill:#D5F5E3,stroke:#1E8449,stroke-width:2px
    style EWM fill:#EAECEE,stroke:#B7950B,stroke-width:2px
    style ESM fill:#FADBD8,stroke:#C0392B,stroke-width:2px
